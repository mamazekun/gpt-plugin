{
  "manifest_version": 3,
  "name": "Chat-Navigator",
  "description": "Extract user questions and provide quick navigation for long AI chat conversations.\n提取用户问题，并为长篇的人工智能聊天对话提供快速导航功能",
  "version": "1.0",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://bard.google.com/*"
      ],
      "js": [
        "dist/content/index.js"
      ],
      "css": [
        "src/content/styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
